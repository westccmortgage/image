# Wallet WCCM — AI Mortgage Strategy Advisor — environment variables.
# Set these in Netlify → Site configuration → Environment variables.
# Nothing here is committed with real values; this file only documents keys.

# ── Live AI advisor (optional) ────────────────────────────────────────────
# Enables the real LLM in /api/mortgage-strategy-advisor. Without it the site
# runs in local advisor mode.
ANTHROPIC_API_KEY=
# Optional model override for the advisor route.
WWCCM_MODEL=

# ── Document Review: storage + broker delivery ────────────────────────────
# Which secure storage provider stores uploaded document bytes.
#   netlify-blobs | supabase | s3 | dev-sim
# PRODUCTION MUST NEVER SIMULATE: `dev-sim` is refused when CONTEXT=production
# unless DOCUMENT_ALLOW_DEV_SIM=true is also set.
DOCUMENT_STORAGE_PROVIDER=netlify-blobs

# The broker delivery channel (required for real delivery). The function only
# reports success after files are stored AND this webhook returns 2xx.
DOCUMENT_REVIEW_WEBHOOK=

# Optional reference address included in the broker notification (not a transport).
DOCUMENT_REVIEW_EMAIL=

# Explicitly allow the dev simulation in a production context (danger — only for
# controlled testing). Leave unset in real production.
DOCUMENT_ALLOW_DEV_SIM=

# ── Provider: netlify-blobs ───────────────────────────────────────────────
# Blobs are PRIVATE. Broker links point to /api/document-file guarded by this
# shared token. Rotating it revokes every previously issued link. Netlify Blobs
# have no automatic expiry — rotate the token to expire access.
DOCUMENT_ACCESS_TOKEN=

# ── Provider: supabase (uses signed URLs with expiry) ─────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=document-review
# Signed-URL lifetime in seconds (supabase & s3). Default 604800 = 7 days.
DOCUMENT_SIGNED_URL_TTL=604800

# ── Provider: s3 (uses presigned GET URLs with expiry) ────────────────────
AWS_REGION=us-east-1
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── CRM lead capture (GR CRM) ─────────────────────────────────────────────
# Held server-side ONLY (used by /api/crm-lead); never exposed to the browser.
# Intentional broker-review submissions (Strategy Review + Document Review
# contact) are forwarded here. Two supported schemes — set ONE:
#
#   Legacy (currently in production): full URL with the token embedded.
GRCRM_WEBHOOK=
#   Split (spec-preferred): URL + separate bearer token sent as Authorization.
GR_CRM_WEBHOOK_URL=
GR_CRM_WEBHOOK_TOKEN=
#
# If no scheme is configured, CRM forwarding is a no-op (501) and the borrower
# flow is unaffected. NOTE: the previously exposed frontend capture token must
# be considered compromised and ROTATED.

# ── Feature flags (fail closed) ───────────────────────────────────────────
# Server flag: set to false/0/off to disable GR CRM delivery (fails closed —
# /api/crm-lead returns 503 and no success is shown).
GRCRM_DELIVERY_ENABLED=
# Client flags (Vite public, build-time) — set to false to disable and show an
# honest degraded state. No secrets — booleans only.
VITE_AI_MORTGAGE_ADVISOR_V2_ENABLED=
VITE_VOICE_INPUT_ENABLED=
VITE_DOCUMENT_REVIEW_ENABLED=
VITE_GRCRM_DELIVERY_ENABLED=

# ── Program / market data (honesty) ───────────────────────────────────────
# There is no live pricing/program feed wired in; all loan paths are labeled
# planning assumptions / broker-review-required. When a verified source is
# connected (see src/site/scenario/programData.ts), paths may become
# "verified current" with an effective date.

# ── Approved delivery channels ────────────────────────────────────────────
# Broker delivery goes through the secure webhook + GR CRM above. Additional
# approved channels (email, CRM, Arive / LOS, secure broker dashboard) can be
# wired in later behind the same adapter without any UI changes. No Telegram.
